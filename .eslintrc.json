{
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-console": "off",
    "no-var": "error",
    "prefer-const": "warn",
    "eqeqeq": ["error", "always"]
  },
  "overrides": [
    {
      "files": ["src/api/dashboard.js"],
      "env": { "browser": true, "node": false }
    }
  ]
}
